<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        StatusDot style set per APP_DESIGN §3.4 Dot + §13.5 (P1-7). 7×7 px
        ellipse with a soft 6 px coloured glow underneath. Replaces six hand-
        rolled <Ellipse> declarations across the sidebar status row, conflict
        row, active-model row, history rows (OK + error), and local-first card.

        Three colour variants — keys match the brand semantic, not the brush
        token, so callers read intent at the call site:
            Dot.Mint   — success / live / brand
            Dot.Amber  — warning (shortcut conflict)
            Dot.Red    — error (failed transcript)

        Glow colour matches the dot's fill. WPF DropShadowEffect can't pull
        from a DynamicResource brush, so the glow Color is hardcoded — these
        three brand colours are deliberately theme-invariant per APP_DESIGN
        §1.3 ("Brand colours stay the same across themes"), so a hardcoded
        glow is correct, not a token-bypass.
    -->

    <Style x:Key="Dot.Mint" TargetType="Ellipse">
        <Setter Property="Width" Value="7"/>
        <Setter Property="Height" Value="7"/>
        <Setter Property="Fill" Value="{DynamicResource Mint}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#4DDBA6" BlurRadius="6"
                                  ShadowDepth="0" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Dot.Amber" TargetType="Ellipse">
        <Setter Property="Width" Value="7"/>
        <Setter Property="Height" Value="7"/>
        <Setter Property="Fill" Value="{DynamicResource WarningAmber}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FFB74D" BlurRadius="6"
                                  ShadowDepth="0" Opacity="0.55"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Dot.Red" TargetType="Ellipse">
        <Setter Property="Width" Value="7"/>
        <Setter Property="Height" Value="7"/>
        <Setter Property="Fill" Value="{DynamicResource ErrorRed}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#EF5350" BlurRadius="6"
                                  ShadowDepth="0" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
