<Window x:Class="KusPus.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KusPus"
        Icon="/icon.ico"
        Width="880" Height="620"
        MinWidth="820" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBg}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        ShowInTaskbar="True">
    <!--
        MainWindow per docs/APP_DESIGN.md §3. System chrome (no custom title bar);
        title bar tint set via DwmSetWindowAttribute in code-behind.
        Closing hides the window (§3.1) — quit only via tray.
        All colours are DynamicResource brushes registered by ThemeTokens — the
        ThemeService flips brush.Color when the user changes the Appearance pref.
    -->
    <Window.Resources>
        <!-- ── Sidebar tab button (RadioButton restyled per §3.2) ─────────── -->
        <Style x:Key="SidebarTab" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Rectangle x:Name="stripe"
                                       Width="3" Height="18"
                                       Fill="{DynamicResource Mint}" RadiusX="2" RadiusY="2"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="-4,0,0,0"
                                       Opacity="0"/>
                            <Border x:Name="bg" CornerRadius="6" Padding="10,9">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="icon"
                                               Grid.Column="0"
                                               Text="{TemplateBinding Tag}"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="16"
                                               Foreground="{DynamicResource SecondaryText}"
                                               VerticalAlignment="Center"/>
                                    <ContentPresenter Grid.Column="1"
                                                      Margin="12,0,0,0"
                                                      VerticalAlignment="Center"
                                                      TextElement.FontFamily="Segoe UI Variable Text, Segoe UI"
                                                      TextElement.FontSize="12.5"
                                                      TextElement.FontWeight="Medium"
                                                      TextElement.Foreground="{DynamicResource SecondaryText}"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverSubtle}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource Surface}"/>
                                <Setter TargetName="icon" Property="Foreground" Value="{DynamicResource Mint}"/>
                                <Setter TargetName="stripe" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="RowCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,14"/>
        </Style>

        <!-- ── Toggle switch (§3.4) — kept dark-styled in both themes for legibility -->
        <Style x:Key="Toggle" TargetType="CheckBox">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="track"
                                Background="{DynamicResource SurfaceElevated}"
                                BorderBrush="{DynamicResource BorderStrong}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Ellipse x:Name="knob"
                                     Width="14" Height="14"
                                     Fill="White"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="3,0,0,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="Black" Direction="270"
                                                      ShadowDepth="1" BlurRadius="3" Opacity="0.3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{DynamicResource Mint}"/>
                                <Setter TargetName="track" Property="BorderBrush" Value="{DynamicResource Mint}"/>
                                <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="knob" Property="Margin" Value="0,0,3,0"/>
                                <Setter TargetName="knob" Property="Fill" Value="#0F1F18"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentButton" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" CornerRadius="5" Padding="14,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.FontFamily="Segoe UI Variable Text, Segoe UI"
                                              TextElement.FontSize="12"
                                              TextElement.FontWeight="Medium"
                                              TextElement.Foreground="{DynamicResource MutedText}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource SurfaceElevated}"/>
                                <Setter TargetName="bg" Property="TextElement.Foreground" Value="{DynamicResource PrimaryText}"/>
                                <Setter TargetName="bg" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Black" Direction="270"
                                                          ShadowDepth="1" BlurRadius="3" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverSubtle}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Keycap" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource KeycapBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource KeycapBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Direction="270"
                                      ShadowDepth="1" BlurRadius="0" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource Sidebar}"
                BorderBrush="{DynamicResource BorderDivider}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="14,14,14,0">
                    <RadioButton Style="{StaticResource SidebarTab}" GroupName="MainTabs"
                                 Content="General" Tag="&#xE713;"
                                 IsChecked="True" Checked="OnTabChecked"
                                 x:Name="TabGeneral"/>
                    <RadioButton Style="{StaticResource SidebarTab}" GroupName="MainTabs"
                                 Content="Audio" Tag="&#xE720;"
                                 Checked="OnTabChecked" x:Name="TabAudio"/>
                    <RadioButton Style="{StaticResource SidebarTab}" GroupName="MainTabs"
                                 Content="Models" Tag="&#xE950;"
                                 Checked="OnTabChecked" x:Name="TabModels"/>
                    <RadioButton Style="{StaticResource SidebarTab}" GroupName="MainTabs"
                                 Content="History" Tag="&#xE81C;"
                                 Checked="OnTabChecked" x:Name="TabHistory"/>
                    <RadioButton Style="{StaticResource SidebarTab}" GroupName="MainTabs"
                                 Content="Privacy" Tag="&#xE72E;"
                                 Checked="OnTabChecked" x:Name="TabPrivacy"/>
                    <RadioButton Style="{StaticResource SidebarTab}" GroupName="MainTabs"
                                 Content="About" Tag="&#xE946;"
                                 Checked="OnTabChecked" x:Name="TabAbout"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="18,8,18,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="7" Height="7" Fill="{DynamicResource Mint}" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#4DDBA6" BlurRadius="6"
                                              ShadowDepth="0" Opacity="0.5"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="StatusLabel"
                               Grid.Column="1"
                               Text="Idle · tiny.en"
                               Foreground="{DynamicResource MutedText}"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="11"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2"
                               Text="⌃⊞"
                               FontFamily="Cascadia Mono, Consolas, monospace"
                               FontSize="11"
                               Foreground="{DynamicResource MutedText}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1"
                      Background="{DynamicResource AppBg}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0">
            <Grid Margin="36,28,36,32">
                <!-- ── General tab ──────────────────────────────────────── -->
                <StackPanel x:Name="ContentGeneral">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Hotkey"/>
                    <Grid HorizontalAlignment="Left" Width="440" Margin="0,0,0,28">
                        <Border x:Name="HotkeyCard"
                                Style="{StaticResource RowCard}"
                                Padding="22,20"
                                Cursor="Hand"
                                MouseLeftButtonDown="OnHotkeyCardClick">
                            <StackPanel>
                                <TextBlock x:Name="HotkeyEyebrow"
                                           Text="HOTKEY"
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="0,0,0,10"/>
                                <StackPanel x:Name="HotkeyKeycaps" Orientation="Horizontal"/>
                                <TextBlock Text="Hold this chord anywhere in Windows to start dictation. Release to stop and paste."
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,14,0,0"/>
                                <TextBlock x:Name="HotkeyHint"
                                           Text="Tap the picker, then press a new chord."
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="11"
                                           Foreground="{DynamicResource DisabledText}"
                                           FontStyle="Italic"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Rectangle x:Name="HotkeyListenBorder"
                                   Stroke="{DynamicResource Mint}"
                                   StrokeThickness="1.5"
                                   StrokeDashArray="4 3"
                                   RadiusX="10" RadiusY="10"
                                   Visibility="Collapsed"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <Border x:Name="ConflictRow"
                            HorizontalAlignment="Left"
                            Width="440"
                            Background="{DynamicResource WarningTint}"
                            BorderBrush="{DynamicResource WarningBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,10"
                            Margin="0,-20,0,28"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{DynamicResource WarningAmber}" VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FFB74D" BlurRadius="6" ShadowDepth="0" Opacity="0.55"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="Shortcut conflict."
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource WarningAmber}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,8,0"/>
                            <TextBlock x:Name="ConflictText"
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="12"
                                       Foreground="{DynamicResource PrimaryText}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Startup"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Launch KusPus when I sign in"
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="Adds a HKCU\Run entry. Tray menu always available either way."
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      x:Name="AutostartToggle"
                                      Style="{StaticResource Toggle}"
                                      VerticalAlignment="Center"
                                      Checked="OnAutostartChanged"
                                      Unchecked="OnAutostartChanged"/>
                        </Grid>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Appearance"/>
                    <Border Style="{StaticResource RowCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Theme"
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="Auto follows the Windows app-mode setting."
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource SurfaceInput}"
                                    BorderBrush="{DynamicResource BorderStrong}"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Padding="2">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="ThemeAuto"
                                                 Style="{StaticResource SegmentButton}"
                                                 GroupName="Theme"
                                                 Content="Auto"
                                                 IsChecked="True"
                                                 Checked="OnThemeChanged"/>
                                    <RadioButton x:Name="ThemeLight"
                                                 Style="{StaticResource SegmentButton}"
                                                 GroupName="Theme"
                                                 Content="Light"
                                                 Checked="OnThemeChanged"/>
                                    <RadioButton x:Name="ThemeDark"
                                                 Style="{StaticResource SegmentButton}"
                                                 GroupName="Theme"
                                                 Content="Dark"
                                                 Checked="OnThemeChanged"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── Audio tab ────────────────────────────────────────── -->
                <StackPanel x:Name="ContentAudio" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Input device"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <StackPanel>
                            <TextBlock x:Name="AudioDeviceTitle"
                                       Text="—"
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource PrimaryText}"/>
                            <TextBlock Text="Default capture device. Picker UI lands in a follow-up cluster."
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="11.5"
                                       Foreground="{DynamicResource MutedText}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Live level"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Microphone level"
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="Bars react to the default capture device when this tab is open."
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <!-- Discord-style level meter: gray placeholder track + mint
                                 fill that grows from the left as input level rises, plus a
                                 thin peak-hold tick that briefly marks the most recent loud
                                 peak before fading. -->
                            <Grid Grid.Column="1" Width="200" Height="28" VerticalAlignment="Center">
                                <Border Height="6"
                                        VerticalAlignment="Center"
                                        CornerRadius="3"
                                        Background="{DynamicResource MeterTrack}"/>
                                <Border x:Name="LevelMeterFill"
                                        Height="6"
                                        Width="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        CornerRadius="3"
                                        Background="{DynamicResource Mint}"/>
                                <Rectangle x:Name="LevelMeterPeak"
                                           Width="2" Height="12"
                                           Fill="{DynamicResource Mint}"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="0"
                                           Opacity="0"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Test transcription"/>
                    <Border Style="{StaticResource RowCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="5-second sample"
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="Records 5 s, transcribes, shows the result inline. Wiring lands in a follow-up cluster."
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Test"
                                    IsEnabled="False"
                                    Padding="14,7"
                                    Background="{DynamicResource SurfaceElevated}"
                                    Foreground="{DynamicResource DisabledText}"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── Models tab ───────────────────────────────────────── -->
                <StackPanel x:Name="ContentModels" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Active model"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{DynamicResource Mint}" VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#4DDBA6" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock x:Name="ActiveModelText"
                                       Text="—"
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource PrimaryText}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Available models"/>
                    <StackPanel x:Name="ModelsList" Margin="0,0,0,12"/>
                    <TextBlock x:Name="ModelsHint"
                               Text="Tap an installed model to activate. Downloading more models lands in Phase 11."
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="11.5"
                               Foreground="{DynamicResource MutedText}"
                               FontStyle="Italic"/>
                </StackPanel>

                <!-- ── History tab ──────────────────────────────────────── -->
                <StackPanel x:Name="ContentHistory" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="History"/>
                    <TextBlock x:Name="HistoryStats"
                               Text="Loading…"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="11.5"
                               Foreground="{DynamicResource MutedText}"
                               Margin="0,0,0,14"/>
                    <StackPanel x:Name="HistoryList"/>
                </StackPanel>

                <!-- ── Privacy tab ──────────────────────────────────────── -->
                <StackPanel x:Name="ContentPrivacy" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Offline mode"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Block all outbound traffic"
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock x:Name="OfflineSubtitle"
                                           Text="KusPus may reach model and crash-report servers when needed."
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="0,3,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox x:Name="OfflineToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource Toggle}"
                                      VerticalAlignment="Center"
                                      Checked="OnOfflineChanged"
                                      Unchecked="OnOfflineChanged"/>
                        </Grid>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Telemetry"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Send opt-in crash reports"
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="No transcript text, audio, or clipboard contents are ever sent."
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="0,3,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox x:Name="CrashReportsToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource Toggle}"
                                      VerticalAlignment="Center"
                                      Checked="OnCrashReportsChanged"
                                      Unchecked="OnCrashReportsChanged"/>
                        </Grid>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Logs"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <StackPanel>
                            <TextBlock x:Name="LogsPath"
                                       Text="—"
                                       FontFamily="Cascadia Mono, Consolas, monospace"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedText}"
                                       TextWrapping="Wrap"/>
                            <Button Content="Open in Explorer"
                                    Click="OnOpenLogsClick"
                                    Padding="14,7"
                                    Background="{DynamicResource SurfaceElevated}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource MintTint}"
                            BorderBrush="{DynamicResource MintBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="Local-first."
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Mint}"/>
                            <TextBlock Text="Audio capture, transcription, and history all stay on this machine. The only network calls KusPus makes are model downloads (Models tab) and — if you opt in — anonymous crash reports."
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="12"
                                       Foreground="{DynamicResource PrimaryText}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── About tab (§3.3 Tab 6) ──────────────────────────── -->
                <StackPanel x:Name="ContentAbout" Visibility="Collapsed"
                            xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">
                    <!-- Header row: 80px brand mark + wordmark + version + build info. -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                        <svgc:SvgViewbox Source="pack://application:,,,/icon.svg"
                                         Height="80" Width="80"
                                         Stretch="Uniform"
                                         VerticalAlignment="Center"/>
                        <StackPanel Margin="22,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="KusPus"
                                       FontFamily="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"
                                       FontSize="32"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryText}"/>
                            <TextBlock x:Name="AboutVersion"
                                       Text="Version —"
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="13"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,4,0,0"/>
                            <TextBlock x:Name="AboutBuildLine"
                                       Text="—"
                                       FontFamily="Cascadia Mono, Consolas, monospace"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedText}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Resources"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Source code"
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="github.com/devangk003/kuspus"
                                           FontFamily="Cascadia Mono, Consolas, monospace"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Open on GitHub"
                                    Click="OnOpenGitHubClick"
                                    Padding="14,7"
                                    Background="{DynamicResource SurfaceElevated}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Log folder"
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock x:Name="AboutLogsPath"
                                           Text="—"
                                           FontFamily="Cascadia Mono, Consolas, monospace"
                                           FontSize="11"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="0,3,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="500"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Open in Explorer"
                                    Click="OnOpenLogsClick"
                                    Padding="14,7"
                                    Background="{DynamicResource SurfaceElevated}"
                                    Foreground="{DynamicResource PrimaryText}"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,32">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Re-run onboarding"
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="Walks through the 7-step first-launch flow again. Wiring lands in Phase 10."
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Run again"
                                    IsEnabled="False"
                                    Padding="14,7"
                                    Background="{DynamicResource SurfaceElevated}"
                                    Foreground="{DynamicResource DisabledText}"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="MIT licensed · Local-first · No telemetry."
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="{DynamicResource SecondaryText}"/>
                    <TextBlock Text="Press a hotkey. Speak. Get pasted."
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="11.5"
                               FontStyle="Italic"
                               Foreground="{DynamicResource MutedText}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
