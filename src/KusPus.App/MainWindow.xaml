<Window x:Class="KusPus.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KusPus"
        Icon="/icon.ico"
        Width="880" Height="620"
        MinWidth="820" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBg}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        ShowInTaskbar="True">
    <!--
        MainWindow per docs/APP_DESIGN.md §3. System chrome (no custom title bar);
        title bar tint set via DwmSetWindowAttribute in code-behind.
        Closing hides the window (§3.1) — quit only via tray.
        All colours are DynamicResource brushes registered by ThemeTokens — the
        ThemeService flips brush.Color when the user changes the Appearance pref.
        Typography styles (SectionHeader, Type.RowTitle, Type.RowSubtitle,
        Type.Eyebrow, Type.MonoSm, Type.Display) live in Styles/Typography.xaml
        per APP_DESIGN §13.5 (P1-6).
    -->
    <Window.Resources>
        <!-- ── Sidebar tab button (RadioButton restyled per §3.2) ─────────── -->
        <Style x:Key="SidebarTab" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="FocusVisualStyle" Value="{DynamicResource Focus.Mint}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Rectangle x:Name="stripe"
                                       Width="3" Height="18"
                                       Fill="{DynamicResource Mint}" RadiusX="2" RadiusY="2"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="-4,0,0,0"
                                       Opacity="0"/>
                            <Border x:Name="bg" CornerRadius="6" Padding="10,9">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="icon"
                                               Grid.Column="0"
                                               Text="{TemplateBinding Tag}"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="16"
                                               Foreground="{DynamicResource SecondaryText}"
                                               VerticalAlignment="Center"/>
                                    <ContentPresenter Grid.Column="1"
                                                      Margin="12,0,0,0"
                                                      VerticalAlignment="Center"
                                                      TextElement.FontFamily="Segoe UI Variable Text, Segoe UI"
                                                      TextElement.FontSize="12.5"
                                                      TextElement.FontWeight="Medium"
                                                      TextElement.Foreground="{DynamicResource SecondaryText}"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverSubtle}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource Surface}"/>
                                <Setter TargetName="icon" Property="Foreground" Value="{DynamicResource Mint}"/>
                                <Setter TargetName="stripe" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SectionHeader moved to Styles/Typography.xaml per APP_DESIGN §13.5 (P1-6). -->

        <Style x:Key="RowCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,14"/>
        </Style>

        <!-- ── Toggle switch (§3.4) — kept dark-styled in both themes for legibility -->
        <Style x:Key="Toggle" TargetType="CheckBox">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{DynamicResource Focus.Mint}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="track"
                                Background="{DynamicResource SurfaceElevated}"
                                BorderBrush="{DynamicResource BorderStrong}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Ellipse x:Name="knob"
                                     Width="14" Height="14"
                                     Fill="White"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="3,0,0,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="Black" Direction="270"
                                                      ShadowDepth="1" BlurRadius="3" Opacity="0.3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{DynamicResource Mint}"/>
                                <Setter TargetName="track" Property="BorderBrush" Value="{DynamicResource Mint}"/>
                                <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="knob" Property="Margin" Value="0,0,3,0"/>
                                <Setter TargetName="knob" Property="Fill" Value="#0F1F18"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentButton" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{DynamicResource Focus.Mint}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" CornerRadius="5" Padding="14,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.FontFamily="Segoe UI Variable Text, Segoe UI"
                                              TextElement.FontSize="12"
                                              TextElement.FontWeight="Medium"
                                              TextElement.Foreground="{DynamicResource MutedText}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource SurfaceElevated}"/>
                                <Setter TargetName="bg" Property="TextElement.Foreground" Value="{DynamicResource PrimaryText}"/>
                                <Setter TargetName="bg" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Black" Direction="270"
                                                          ShadowDepth="1" BlurRadius="3" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverSubtle}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Keycap" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource KeycapBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource KeycapBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Direction="270"
                                      ShadowDepth="1" BlurRadius="0" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── History table row (audit follow-up: History as table, not card list) ── -->
        <Style x:Key="HistoryRow" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDivider}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="14,8,14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverSubtle}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource Sidebar}"
                BorderBrush="{DynamicResource BorderDivider}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="14,14,14,0">
                    <RadioButton Style="{StaticResource SidebarTab}" GroupName="MainTabs"
                                 Content="General" Tag="&#xE713;"
                                 IsChecked="True" Checked="OnTabChecked"
                                 x:Name="TabGeneral"/>
                    <RadioButton Style="{StaticResource SidebarTab}" GroupName="MainTabs"
                                 Content="Audio" Tag="&#xE720;"
                                 Checked="OnTabChecked" x:Name="TabAudio"/>
                    <RadioButton Style="{StaticResource SidebarTab}" GroupName="MainTabs"
                                 Content="Models" Tag="&#xE950;"
                                 Checked="OnTabChecked" x:Name="TabModels"/>
                    <RadioButton Style="{StaticResource SidebarTab}" GroupName="MainTabs"
                                 Content="History" Tag="&#xE81C;"
                                 Checked="OnTabChecked" x:Name="TabHistory"/>
                    <RadioButton Style="{StaticResource SidebarTab}" GroupName="MainTabs"
                                 Content="Privacy" Tag="&#xE72E;"
                                 Checked="OnTabChecked" x:Name="TabPrivacy"/>
                    <RadioButton Style="{StaticResource SidebarTab}" GroupName="MainTabs"
                                 Content="About" Tag="&#xE946;"
                                 Checked="OnTabChecked" x:Name="TabAbout"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="18,8,18,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Style="{StaticResource Dot.Mint}"/>
                    <TextBlock x:Name="StatusLabel"
                               Grid.Column="1"
                               Text="—"
                               Style="{StaticResource Type.MonoSm}"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="SidebarHotkeyGlyph"
                               Grid.Column="2"
                               Text="—"
                               Style="{StaticResource Type.MonoSm}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1"
                      Background="{DynamicResource AppBg}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0">
            <Grid Margin="36,28,36,32">
                <!-- ── General tab ──────────────────────────────────────── -->
                <StackPanel x:Name="ContentGeneral">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Hotkey"/>
                    <!-- §13.5 P1-8 / P2-5: hotkey card + conflict row share a single
                         440 px-wide column StackPanel so the conflict row sits 1 px
                         below the card when visible, and the section gap (28 px) is
                         owned by the wrapper instead of by a negative-margin tuck. -->
                    <StackPanel HorizontalAlignment="Left" Width="440" Margin="0,0,0,28">
                        <Grid>
                            <Border x:Name="HotkeyCard"
                                    Style="{StaticResource RowCard}"
                                    Padding="22,20"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="OnHotkeyCardClick">
                                <StackPanel>
                                    <TextBlock x:Name="HotkeyEyebrow"
                                               Text="HOTKEY"
                                               Style="{StaticResource Type.Eyebrow}"
                                               Margin="0,0,0,10"/>
                                    <StackPanel x:Name="HotkeyKeycaps" Orientation="Horizontal"/>
                                    <TextBlock Text="Hold this chord anywhere in Windows to start dictation. Release to stop and paste."
                                               Style="{StaticResource Type.RowSubtitle}"
                                               Margin="0,14,0,0"/>
                                    <TextBlock x:Name="HotkeyHint"
                                               Text="Tap the picker, then press a new chord."
                                               FontFamily="Segoe UI Variable Text, Segoe UI"
                                               FontSize="11"
                                               Foreground="{DynamicResource DisabledText}"
                                               FontStyle="Italic"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Rectangle x:Name="HotkeyListenBorder"
                                       Stroke="{DynamicResource Mint}"
                                       StrokeThickness="1.5"
                                       StrokeDashArray="4 3"
                                       RadiusX="10" RadiusY="10"
                                       Visibility="Collapsed"
                                       IsHitTestVisible="False"/>
                        </Grid>

                        <Border x:Name="ConflictRow"
                                Background="{DynamicResource WarningTint}"
                                BorderBrush="{DynamicResource WarningBorder}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,10"
                                Margin="0,1,0,0"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Style="{StaticResource Dot.Amber}"/>
                                <TextBlock Text="Shortcut conflict."
                                           Style="{StaticResource Type.WarningEmphasis}"
                                           VerticalAlignment="Center"
                                           Margin="10,0,8,0"/>
                                <TextBlock x:Name="ConflictText"
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="12"
                                           Foreground="{DynamicResource PrimaryText}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Startup"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Launch KusPus when I sign in"
                                           Style="{StaticResource Type.RowTitle}"/>
                                <TextBlock Text="Starts KusPus when you sign in to Windows. The tray icon stays available either way."
                                           Style="{StaticResource Type.RowSubtitle}"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      x:Name="AutostartToggle"
                                      Style="{StaticResource Toggle}"
                                      VerticalAlignment="Center"
                                      Checked="OnAutostartChanged"
                                      Unchecked="OnAutostartChanged"/>
                        </Grid>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Appearance"/>
                    <Border Style="{StaticResource RowCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Theme"
                                           Style="{StaticResource Type.RowTitle}"/>
                                <TextBlock Text="Auto follows the Windows app-mode setting."
                                           Style="{StaticResource Type.RowSubtitle}"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource SurfaceInput}"
                                    BorderBrush="{DynamicResource BorderStrong}"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Padding="2">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="ThemeAuto"
                                                 Style="{StaticResource SegmentButton}"
                                                 GroupName="Theme"
                                                 Content="Auto"
                                                 IsChecked="True"
                                                 Checked="OnThemeChanged"/>
                                    <RadioButton x:Name="ThemeLight"
                                                 Style="{StaticResource SegmentButton}"
                                                 GroupName="Theme"
                                                 Content="Light"
                                                 Checked="OnThemeChanged"/>
                                    <RadioButton x:Name="ThemeDark"
                                                 Style="{StaticResource SegmentButton}"
                                                 GroupName="Theme"
                                                 Content="Dark"
                                                 Checked="OnThemeChanged"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── Audio tab ────────────────────────────────────────── -->
                <StackPanel x:Name="ContentAudio" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Input device"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <StackPanel>
                            <TextBlock x:Name="AudioDeviceTitle"
                                       Text="—"
                                       Style="{StaticResource Type.RowTitle}"/>
                            <TextBlock Text="Default capture device. Follows your Windows microphone selection."
                                       Style="{StaticResource Type.RowSubtitle}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Live level"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Microphone level"
                                           Style="{StaticResource Type.RowTitle}"/>
                                <TextBlock Text="Active only while this tab is open. Audio is never recorded."
                                           Style="{StaticResource Type.RowSubtitle}"/>
                            </StackPanel>
                            <!-- Discord-style level meter: gray placeholder track + mint
                                 fill that grows from the left as input level rises, plus a
                                 thin peak-hold tick that briefly marks the most recent loud
                                 peak before fading. -->
                            <Grid Grid.Column="1" Width="200" Height="28" VerticalAlignment="Center">
                                <Border Height="6"
                                        VerticalAlignment="Center"
                                        CornerRadius="3"
                                        Background="{DynamicResource MeterTrack}"/>
                                <Border x:Name="LevelMeterFill"
                                        Height="6"
                                        Width="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        CornerRadius="3"
                                        Background="{DynamicResource Mint}"/>
                                <Rectangle x:Name="LevelMeterPeak"
                                           Width="2" Height="12"
                                           Fill="{DynamicResource Mint}"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="0"
                                           Opacity="0"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- "Test transcription" section removed per APP_DESIGN §13.5 (P0-2):
                         the Test button was permanently disabled with a "lands later"
                         note; per §13.2, deferred features hide their UI rather than
                         ship a promise-with-no-affordance. Restore in W3 when wired. -->
                </StackPanel>

                <!-- ── Models tab ───────────────────────────────────────── -->
                <StackPanel x:Name="ContentModels" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Active model"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Style="{StaticResource Dot.Mint}"/>
                            <TextBlock x:Name="ActiveModelText"
                                       Text="—"
                                       Style="{StaticResource Type.RowTitle}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Available models"/>
                    <StackPanel x:Name="ModelsList" Margin="0,0,0,16"/>
                    <TextBlock x:Name="ModelsHint"
                               Text="Tap an installed model to activate. The bundled tiny model ships with KusPus."
                               Style="{StaticResource Type.RowSubtitle}"
                               FontStyle="Italic"
                               Margin="0"/>
                </StackPanel>

                <!-- ── History tab (§3.3 Tab 4 + §13.5 P1-2) ────────────────── -->
                <StackPanel x:Name="ContentHistory" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="History"/>

                    <!-- Search bar — debounced full-text against transcripts_fts. -->
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,16" Padding="14,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE721;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="{DynamicResource MutedText}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     x:Name="HistorySearchBox"
                                     Margin="10,0,0,0"
                                     Padding="0,2"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource PrimaryText}"
                                     CaretBrush="{DynamicResource PrimaryText}"
                                     FontFamily="Segoe UI Variable Text, Segoe UI"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     TextChanged="OnHistorySearchChanged"/>
                            <TextBlock x:Name="HistorySearchPlaceholder"
                                       Grid.Column="1"
                                       Text="Search transcripts…"
                                       Margin="10,0,0,0"
                                       Foreground="{DynamicResource MutedText}"
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                            <Button Grid.Column="2"
                                    x:Name="HistorySearchClear"
                                    Content="&#xE711;"
                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                    FontSize="11"
                                    Background="Transparent"
                                    Foreground="{DynamicResource MutedText}"
                                    BorderThickness="0"
                                    Padding="6,2"
                                    Margin="6,0,0,0"
                                    Cursor="Hand"
                                    Visibility="Collapsed"
                                    Click="OnHistorySearchClearClick"/>
                        </Grid>
                    </Border>

                    <!-- Table header row. Same Grid column geometry as each body row
                         in BuildHistoryRow so the eyebrow labels align over their data
                         columns. Status column intentionally has no label. -->
                    <Border Padding="14,10,14,10"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="78"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="52"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="TIME"
                                       Style="{StaticResource Type.Eyebrow}"
                                       Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="2" Text="APP"
                                       Style="{StaticResource Type.Eyebrow}"
                                       Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="3" Text="TRANSCRIPT"
                                       Style="{StaticResource Type.Eyebrow}"
                                       Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="4" Text="MODEL"
                                       Style="{StaticResource Type.Eyebrow}"
                                       Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="5" Text="DUR"
                                       Style="{StaticResource Type.Eyebrow}"
                                       TextAlignment="Right"/>
                        </Grid>
                    </Border>

                    <StackPanel x:Name="HistoryList"/>

                    <!-- Bulk footer (§3.3 Tab 4 #3). -->
                    <Border Margin="0,16,0,0"
                            BorderBrush="{DynamicResource BorderDivider}"
                            BorderThickness="0,1,0,0"
                            Padding="0,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="HistoryStats"
                                       Grid.Column="0"
                                       Text="—"
                                       Style="{StaticResource Type.RowSubtitle}"
                                       Margin="0"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    x:Name="PurgeAllButton"
                                    Content="Purge all history"
                                    Style="{StaticResource Btn.Danger}"
                                    Click="OnPurgeAllClick"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── Privacy tab ──────────────────────────────────────── -->
                <StackPanel x:Name="ContentPrivacy" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Offline mode"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Block all outbound traffic"
                                           Style="{StaticResource Type.RowTitle}"/>
                                <TextBlock x:Name="OfflineSubtitle"
                                           Text="KusPus may reach model and crash-report servers when needed."
                                           Style="{StaticResource Type.RowSubtitle}"/>
                            </StackPanel>
                            <CheckBox x:Name="OfflineToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource Toggle}"
                                      VerticalAlignment="Center"
                                      Checked="OnOfflineChanged"
                                      Unchecked="OnOfflineChanged"/>
                        </Grid>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Telemetry"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Send opt-in crash reports"
                                           Style="{StaticResource Type.RowTitle}"/>
                                <TextBlock x:Name="CrashReportsSubtitle"
                                           Text="Anonymous, opt-in. Never includes transcripts, audio, or clipboard contents."
                                           Style="{StaticResource Type.RowSubtitle}"/>
                            </StackPanel>
                            <CheckBox x:Name="CrashReportsToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource Toggle}"
                                      VerticalAlignment="Center"
                                      Checked="OnCrashReportsChanged"
                                      Unchecked="OnCrashReportsChanged"/>
                        </Grid>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Logs"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,28">
                        <StackPanel>
                            <!-- Row 1: total log size + Clear logs (§13.5 P1-3). -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Log size"
                                               Style="{StaticResource Type.RowTitle}"/>
                                    <TextBlock x:Name="LogsSize"
                                               Text="Calculating…"
                                               Style="{StaticResource Type.RowSubtitle}"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Clear logs"
                                        Style="{StaticResource Btn.Danger}"
                                        Click="OnClearLogsClick"
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <Border Height="1"
                                    Background="{DynamicResource BorderDivider}"
                                    Margin="0,14,0,14"/>

                            <!-- Row 2: folder path + Open in Explorer. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Log folder"
                                               Style="{StaticResource Type.RowTitle}"/>
                                    <TextBlock x:Name="LogsPath"
                                               Text="—"
                                               Style="{StaticResource Type.MonoSm}"
                                               Margin="0,3,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="500"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Open in Explorer"
                                        Click="OnOpenLogsClick"
                                        Style="{StaticResource Btn.Secondary}"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource MintTint}"
                            BorderBrush="{DynamicResource MintBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="Local-first."
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Mint}"/>
                            <TextBlock Text="Audio capture, transcription, and history all stay on this machine. The only network calls KusPus makes are model downloads (Models tab) and — if you opt in — anonymous crash reports."
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="12"
                                       Foreground="{DynamicResource PrimaryText}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── About tab (§3.3 Tab 6) ──────────────────────────── -->
                <StackPanel x:Name="ContentAbout" Visibility="Collapsed"
                            xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">
                    <!-- Header row: 80px brand mark + wordmark + version + build info. -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                        <svgc:SvgViewbox Source="pack://application:,,,/icon.svg"
                                         Height="80" Width="80"
                                         Stretch="Uniform"
                                         VerticalAlignment="Center"/>
                        <StackPanel Margin="22,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="KusPus"
                                       Style="{StaticResource Type.Display}"/>
                            <TextBlock x:Name="AboutVersion"
                                       Text="Version —"
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="13"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,4,0,0"/>
                            <TextBlock x:Name="AboutBuildLine"
                                       Text="—"
                                       Style="{StaticResource Type.MonoSm}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Resources"/>
                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Source code"
                                           Style="{StaticResource Type.RowTitle}"/>
                                <TextBlock Text="github.com/devangk003/kuspus"
                                           Style="{StaticResource Type.MonoSm}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Open on GitHub"
                                    Click="OnOpenGitHubClick"
                                    Style="{StaticResource Btn.Secondary}"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Log folder"
                                           Style="{StaticResource Type.RowTitle}"/>
                                <TextBlock x:Name="AboutLogsPath"
                                           Text="—"
                                           Style="{StaticResource Type.MonoSm}"
                                           Margin="0,3,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="500"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Open in Explorer"
                                    Click="OnOpenLogsClick"
                                    Style="{StaticResource Btn.Secondary}"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource RowCard}" Margin="0,0,0,32">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Re-run onboarding"
                                           Style="{StaticResource Type.RowTitle}"/>
                                <TextBlock Text="Walks through the 7-step first-launch flow again."
                                           Style="{StaticResource Type.RowSubtitle}"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Run again"
                                    Click="OnRerunOnboardingClick"
                                    Style="{StaticResource Btn.Secondary}"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="MIT licensed · Local-first · No telemetry."
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="{DynamicResource SecondaryText}"/>
                    <TextBlock Text="Press a hotkey. Speak. Get pasted."
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="11.5"
                               FontStyle="Italic"
                               Foreground="{DynamicResource MutedText}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
