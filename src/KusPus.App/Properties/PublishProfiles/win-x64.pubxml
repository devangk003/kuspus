<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 12 release publish profile per 2025 best-practices research
    (2026-05-17). Invoke with:
        dotnet publish src/KusPus.App -p:PublishProfile=win-x64 -o publish/win-x64

    Lives here (not in KusPus.App.csproj) so dev builds (`dotnet build`,
    `dotnet test`) don't pay the self-contained / R2R / single-file cost on
    every iteration. Only `dotnet publish` with this profile fires these
    properties.

    Property choices:
      SelfContained                  testers don't install .NET 10 runtime
      PublishSingleFile              one launcher .exe (~80 MB compressed)
      IncludeNativeLibrariesForSelfExtract
                                     packs runtime native DLLs into the .exe;
                                     a handful (rasterizers) still ship
                                     side-by-side
      EnableCompressionInSingleFile  ~30-40% smaller payload; one-time
                                     ~200 ms decompression at first launch
      PublishReadyToRun              warmer cold-start; +~15 MB
      PublishTrimmed=false           WPF + SharpVectors XAML/reflection
                                     break under any trim level
      DebugType=embedded             .pdb embedded so Sentry symbol
                                     resolution works without a side file
      RuntimeIdentifier=win-x64      x64 only — PRD non-goal N-09 keeps
                                     ARM64 out of v1.0
      Configuration=Release          dev publish should also be Release
                                     (otherwise the smoke output isn't
                                     representative)

    Per dotnet/sdk#51888: SelfContained must be set explicitly when
    PublishSingleFile=true is set — the implicit fallback is unreliable
    in the .NET 10 SDK.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>bin\Release\net10.0-windows\publish\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>

    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>embedded</DebugType>
  </PropertyGroup>
</Project>
