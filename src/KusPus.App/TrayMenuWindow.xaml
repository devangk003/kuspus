<Window x:Class="KusPus.App.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="KusPus Tray Menu"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Deactivated="OnDeactivated">
    <!--
        Tray right-click menu per the user-supplied design (Tray_light.png /
        Tray_dark.png). Floating card with rounded corners + drop shadow,
        anchored above the tray cursor. Closes on Deactivated (focus lost) or
        on any item click. Items match docs/APP_DESIGN.md §5.2 plus the
        Active-model affordance and a hotkey keycap hint for Toggle recorder.
    -->
    <Window.Resources>
        <!-- Self-contained styles — TrayMenuWindow lives outside MainWindow's
             resource scope so we don't reach into its private styles. Reuses
             the global theme tokens (HoverSubtle, BorderStrong, KeycapBg etc.). -->
        <Style x:Key="TrayMenuItemButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background"
                                        Value="{DynamicResource HoverSubtle}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Keycap" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource KeycapBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource KeycapBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="MinWidth" Value="22"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource BorderStrong}"
            BorderThickness="1"
            CornerRadius="12"
            MinWidth="240"
            Padding="6,6,6,6">
        <Border.Effect>
            <DropShadowEffect Color="Black"
                              Direction="270"
                              ShadowDepth="4"
                              BlurRadius="20"
                              Opacity="0.35"/>
        </Border.Effect>

        <StackPanel>
            <!-- ── Header ────────────────────────────────────────────── -->
            <Grid Margin="10,6,10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <svgc:SvgViewbox Grid.Column="0"
                                 Source="pack://application:,,,/icon.svg"
                                 Width="22" Height="22"
                                 Margin="0,2,10,0"
                                 VerticalAlignment="Top"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="KusPus"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}"/>
                    <TextBlock x:Name="VersionSubtitle"
                               Text="Version 1.0.0 · Idle"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="11"
                               FontWeight="Regular"
                               Foreground="{DynamicResource MutedText}"
                               Margin="0,1,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Divider -->
            <Rectangle Height="1" Fill="{DynamicResource BorderDivider}" Margin="6,2,6,4"/>

            <!-- ── Toggle recorder ──────────────────────────────────── -->
            <Button x:Name="ToggleRecorderButton"
                    Click="OnToggleRecorderClick"
                    Style="{StaticResource TrayMenuItemButton}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="&#xE720;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Toggle Recording"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource PrimaryText}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="[BETA]"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Mint}"
                                   VerticalAlignment="Center"
                                   Margin="8,1,0,0"/>
                    </StackPanel>
                    <Border x:Name="HotkeyKeycap"
                            Grid.Column="2"
                            Style="{StaticResource Keycap}"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="HotkeyKeycapText"
                                   Text="—"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="10"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource SecondaryText}"/>
                    </Border>
                </Grid>
            </Button>

            <!-- ── Active model ─────────────────────────────────────── -->
            <Button x:Name="ActiveModelButton"
                    Click="OnActiveModelClick"
                    Style="{StaticResource TrayMenuItemButton}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="&#xEA3A;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Active model:"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource PrimaryText}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="ActiveModelText"
                                   Text="tiny.en"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Mint}"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="&#xE76C;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="10"
                               Foreground="{DynamicResource MutedText}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Button>

            <Rectangle Height="1" Fill="{DynamicResource BorderDivider}" Margin="6,4,6,4"/>

            <!-- ── Preferences ──────────────────────────────────────── -->
            <Button Click="OnPreferencesClick" Style="{StaticResource TrayMenuItemButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <TextBlock Text="Preferences…"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="13"
                               FontWeight="Medium"
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- ── History ──────────────────────────────────────────── -->
            <Button Click="OnHistoryClick" Style="{StaticResource TrayMenuItemButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE823;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <TextBlock Text="History…"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="13"
                               FontWeight="Medium"
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Rectangle Height="1" Fill="{DynamicResource BorderDivider}" Margin="6,4,6,4"/>

            <!-- ── Quit ─────────────────────────────────────────────── -->
            <Button Click="OnQuitClick" Style="{StaticResource TrayMenuItemButton}">
                <TextBlock Text="Quit"
                           FontFamily="Segoe UI Variable Text, Segoe UI"
                           FontSize="13"
                           FontWeight="Medium"
                           Foreground="{DynamicResource ErrorRed}"
                           VerticalAlignment="Center"/>
            </Button>
        </StackPanel>
    </Border>
</Window>
