<Window x:Class="KusPus.App.FloatingPillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="KusPus"
        Icon="/icon.ico"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Width="200" Height="56"
        MinWidth="200" MaxWidth="280"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="Manual"
        MouseEnter="OnPillMouseEnter"
        MouseLeave="OnPillMouseLeave">
    <!--
        Pill surface per docs/PILL_DESIGN.md.
            200×56, 8px rounded corners. Mica on Win11 (DWMWA_SYSTEMBACKDROP_TYPE).
            Surface gradient, border, text & visualizer all bind to ThemeTokens
            via {DynamicResource}, so flipping Auto/Light/Dark in Preferences
            re-themes the pill in lock-step with the MainWindow.
            §10 hover-extend override: width animates 200→280 on hover, revealing
              two icon buttons (Settings placeholder + Close) on the right.
    -->
    <Border x:Name="PillSurface" CornerRadius="8"
            Background="{DynamicResource PillSurface}"
            BorderBrush="{DynamicResource PillBorder}"
            BorderThickness="1"
            MouseLeftButtonDown="OnPillMouseLeftButtonDown">
        <Border.Effect>
            <!-- §3.3 dark shadow — kept black in both themes; barely visible behind
                 a light pill anyway. -->
            <DropShadowEffect Color="Black" Direction="270"
                              ShadowDepth="2" BlurRadius="32" Opacity="0.45"/>
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <Rectangle Grid.ColumnSpan="2"
                       VerticalAlignment="Top"
                       Height="1"
                       Fill="{DynamicResource PillInnerHighlight}"/>

            <Grid Grid.Column="0">
                <Rectangle x:Name="AccentLine"
                           VerticalAlignment="Top"
                           HorizontalAlignment="Center"
                           Width="136" Height="1.5"
                           Opacity="0">
                    <Rectangle.Fill>
                        <LinearGradientBrush x:Name="AccentBrush" StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#004DDBA6" Offset="0.0"/>
                            <GradientStop Color="#804DDBA6" Offset="0.5"/>
                            <GradientStop Color="#004DDBA6" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.Effect>
                        <DropShadowEffect x:Name="AccentGlow"
                                          Color="#4DDBA6" BlurRadius="8"
                                          ShadowDepth="0" Opacity="0.6"/>
                    </Rectangle.Effect>
                </Rectangle>

                <StackPanel x:Name="IdleContent"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0"
                            IsHitTestVisible="False">
                    <svgc:SvgViewbox Source="pack://application:,,,/icon.svg"
                                     Height="17"
                                     Stretch="Uniform"
                                     VerticalAlignment="Center"
                                     SnapsToDevicePixels="True"
                                     UseLayoutRounding="True"/>
                    <TextBlock Text="KusPus"
                               Foreground="{DynamicResource MutedText}"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="13"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </StackPanel>

                <Grid x:Name="RecordingContent" Opacity="0" IsHitTestVisible="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Canvas x:Name="VisualizerCanvas"
                            Grid.Row="0"
                            Width="136" Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,2"/>
                    <TextBlock Grid.Row="1"
                               Text="RECORDING"
                               Foreground="{DynamicResource MutedText}"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="9.5"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                </Grid>

                <StackPanel x:Name="TranscribingContent"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,2,0,0"
                            Opacity="0"
                            IsHitTestVisible="False">
                    <Canvas Width="14" Height="14" VerticalAlignment="Center">
                        <Path Stroke="{DynamicResource PrimaryText}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 7,1.5 A 5.5,5.5 0 1 1 1.5,7">
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotation"
                                                 Angle="0"
                                                 CenterX="7" CenterY="7"/>
                            </Path.RenderTransform>
                        </Path>
                    </Canvas>
                    <TextBlock Text="Transcribing…"
                               Foreground="{DynamicResource PrimaryText}"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="13"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </StackPanel>

                <TextBlock x:Name="ConfirmedContent"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable Text, Segoe UI"
                           FontSize="13"
                           FontWeight="Medium"
                           Foreground="{DynamicResource PrimaryText}"
                           Opacity="0"
                           IsHitTestVisible="False">
                    <Run Text="Pasted into "/>
                    <Run x:Name="ConfirmedAppRun"
                         FontWeight="SemiBold"
                         Text=""/>
                </TextBlock>

                <StackPanel x:Name="ErrorContent"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0"
                            IsHitTestVisible="False">
                    <Ellipse Width="5" Height="5" Fill="#FF4D4F" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#FF4D4F" BlurRadius="6"
                                              ShadowDepth="0" Opacity="0.7"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="ErrorText"
                               Text=""
                               Foreground="{DynamicResource PrimaryText}"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="12.5"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="120"/>
                </StackPanel>
            </Grid>

            <StackPanel x:Name="ButtonPanel"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0"
                        IsHitTestVisible="False">
                <Button x:Name="SettingsButton"
                        Width="28" Height="28"
                        Margin="0,0,4,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Settings — coming soon"
                        Click="OnSettingsClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource ButtonHoverBg}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="14"
                               Foreground="{DynamicResource SecondaryText}"/>
                </Button>

                <Button x:Name="CloseButton"
                        Width="28" Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Quit KusPus"
                        Click="OnCloseClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#33FF4D4F"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="11"
                               Foreground="{DynamicResource PrimaryText}"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
