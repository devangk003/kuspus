<Window x:Class="KusPus.App.FloatingPillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="KusPus"
        Icon="/icon.ico"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Width="200" Height="56"
        MinWidth="200" MaxWidth="280"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="Manual"
        MouseEnter="OnPillMouseEnter"
        MouseLeave="OnPillMouseLeave">
    <!--
        Pill surface per docs/PILL_DESIGN.md.
            200×56, 8px rounded corners. Mica on Win11 (DWMWA_SYSTEMBACKDROP_TYPE).
            §3.1 dark surface gradient + §3.3 hairline border + drop shadow.
            §10 hover-extend override: width animates 200→280 on hover, revealing
              two icon buttons (Settings placeholder + Close) on the right.
            Click-through DISABLED (§10.2): pill captures hover so the buttons work.
            Focus theft still prevented via WS_EX_NOACTIVATE (§6.3).
    -->
    <Border x:Name="PillSurface" CornerRadius="8"
            MouseLeftButtonDown="OnPillMouseLeftButtonDown">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <!-- §3.1: rgba(38,38,40,0.88) → rgba(28,28,30,0.92) -->
                <GradientStop Color="#E0262628" Offset="0"/>
                <GradientStop Color="#EB1C1C1E" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="White" Opacity="0.07"/>
        </Border.BorderBrush>
        <Border.BorderThickness>1</Border.BorderThickness>
        <Border.Effect>
            <!-- §3.3 dark shadow (the large diffuse layer; smaller contact layer is left to DWM Mica) -->
            <DropShadowEffect Color="Black" Direction="270"
                              ShadowDepth="2" BlurRadius="32" Opacity="0.45"/>
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <!-- §3.3 inner top highlight, spans full width. -->
            <Rectangle Grid.ColumnSpan="2"
                       VerticalAlignment="Top"
                       Height="1"
                       Fill="White"
                       Opacity="0.05"/>

            <!-- Main 200×56 content column. -->
            <Grid Grid.Column="0">
                <!-- §3.4 accent line: 136×1.5, gradient-faded ends, top edge. -->
                <Rectangle x:Name="AccentLine"
                           VerticalAlignment="Top"
                           HorizontalAlignment="Center"
                           Width="136" Height="1.5"
                           Opacity="0">
                    <Rectangle.Fill>
                        <LinearGradientBrush x:Name="AccentBrush" StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#004DDBA6" Offset="0.0"/>
                            <GradientStop Color="#804DDBA6" Offset="0.5"/>
                            <GradientStop Color="#004DDBA6" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.Effect>
                        <!-- §3.4 outer glow when accent is at full opacity. -->
                        <DropShadowEffect x:Name="AccentGlow"
                                          Color="#4DDBA6" BlurRadius="8"
                                          ShadowDepth="0" Opacity="0.6"/>
                    </Rectangle.Effect>
                </Rectangle>

                <!-- ── Idle state: app icon + "KusPus" label (PRD G4 dev override) ──
                     Spec §6.1 says no idle pill, but we keep one for now so the
                     hover-extend close button is always reachable. The icon is
                     loaded directly from icons/icon.svg via SharpVectors so the
                     SVG file is the single source of truth (no hand-converted
                     XAML to drift from it). Aspect ratio is locked by SvgViewbox
                     Stretch="Uniform"; resizing is just the Height value. -->
                <StackPanel x:Name="IdleContent"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0"
                            IsHitTestVisible="False">
                    <svgc:SvgViewbox Source="pack://application:,,,/icon.svg"
                                     Height="17"
                                     Stretch="Uniform"
                                     VerticalAlignment="Center"
                                     SnapsToDevicePixels="True"
                                     UseLayoutRounding="True"/>
                    <TextBlock Text="KusPus"
                               Foreground="#8CFFFFFF"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="13"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </StackPanel>

                <!-- ── Recording state: visualizer + RECORDING label ────────── -->
                <Grid x:Name="RecordingContent" Opacity="0" IsHitTestVisible="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Canvas x:Name="VisualizerCanvas"
                            Grid.Row="0"
                            Width="136" Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,2"/>
                    <!-- §3.5 micro-label: 9.5 px, uppercase, weight 500. Spec asks for
                         letter-spacing 0.08 em which WPF doesn't expose cleanly; the
                         visual width difference at this size is sub-pixel and we
                         skip it. -->
                    <TextBlock Grid.Row="1"
                               Text="RECORDING"
                               Foreground="#8CFFFFFF"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="9.5"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                </Grid>

                <!-- ── Transcribing state: spinner + text ───────────────────── -->
                <StackPanel x:Name="TranscribingContent"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,2,0,0"
                            Opacity="0"
                            IsHitTestVisible="False">
                    <!-- 14px arc spinner — 270° (¾ circle), 1.5px stroke, rotated by code-behind.
                         Rotation pivot is (7,7) in the path's local coordinates — the visual
                         center of the arc. We deliberately do NOT set RenderTransformOrigin
                         on the Path: combined with CenterX/Y, it makes the icon orbit instead
                         of spinning in place. -->
                    <Canvas Width="14" Height="14" VerticalAlignment="Center">
                        <Path Stroke="#F5FFFFFF"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 7,1.5 A 5.5,5.5 0 1 1 1.5,7">
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotation"
                                                 Angle="0"
                                                 CenterX="7" CenterY="7"/>
                            </Path.RenderTransform>
                        </Path>
                    </Canvas>
                    <TextBlock Text="Transcribing…"
                               Foreground="#F5FFFFFF"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="13"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </StackPanel>

                <!-- ── Confirmed state: "Pasted into <App>" ─────────────────── -->
                <TextBlock x:Name="ConfirmedContent"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable Text, Segoe UI"
                           FontSize="13"
                           FontWeight="Medium"
                           Opacity="0"
                           IsHitTestVisible="False">
                    <Run Foreground="#F5FFFFFF" Text="Pasted into "/>
                    <Run x:Name="ConfirmedAppRun"
                         Foreground="#F5FFFFFF"
                         FontWeight="SemiBold"
                         Text=""/>
                </TextBlock>

                <!-- ── Error state: red dot + reason ────────────────────────── -->
                <StackPanel x:Name="ErrorContent"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0"
                            IsHitTestVisible="False">
                    <Ellipse Width="5" Height="5" Fill="#FF4D4F" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#FF4D4F" BlurRadius="6"
                                              ShadowDepth="0" Opacity="0.7"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="ErrorText"
                               Text=""
                               Foreground="#F5FFFFFF"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="12.5"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="120"/>
                </StackPanel>
            </Grid>

            <!-- ── Hover-extend right column (§10) ──────────────────────────── -->
            <StackPanel x:Name="ButtonPanel"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0"
                        IsHitTestVisible="False">
                <Button x:Name="SettingsButton"
                        Width="28" Height="28"
                        Margin="0,0,4,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#8CFFFFFF"
                        Cursor="Hand"
                        ToolTip="Settings — coming soon"
                        Click="OnSettingsClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#22FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="14"
                               Foreground="#C8FFFFFF"/>
                </Button>

                <Button x:Name="CloseButton"
                        Width="28" Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#F5FFFFFF"
                        Cursor="Hand"
                        ToolTip="Quit KusPus"
                        Click="OnCloseClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#33FF4D4F"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="11"
                               Foreground="#F5FFFFFF"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
