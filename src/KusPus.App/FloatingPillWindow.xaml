<Window x:Class="KusPus.App.FloatingPillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#CC0000"
        Width="420" Height="80"
        ResizeMode="NoResize"
        Focusable="False"
        WindowStartupLocation="Manual">
    <!-- DEBUG: bright red so we can SEE if it appears at all on Win 11 25H2. -->
    <Grid>
        <TextBlock x:Name="StatusText"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   FontFamily="Segoe UI"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Text="KusPus" />
    </Grid>
</Window>
