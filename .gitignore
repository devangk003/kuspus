# Build output
bin/
obj/
out/
publish/
[Bb]in/
[Oo]bj/

# Visual Studio
.vs/
*.user
*.userprefs
*.suo
*.sln.docstates

# Rider / JetBrains
.idea/
*.DotSettings.user

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# NuGet
*.nupkg
*.snupkg
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# Native build artifacts
third_party/whisper.cpp/build/
third_party/whisper.cpp/build-*/

# Installer payload (rebuilt locally each release)
installer/payload/
installer/Output/

# Logs and local data
*.log
*.tmp
*.bak

# Test results
[Tt]est[Rr]esults/

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Sentry DSN / secrets (just in case)
*.secrets
secrets.json

# .NET tools cache
.dotnet/

# Claude Code session state (per-user, not for VCS)
.claude/

# Local model storage (junction target from %LOCALAPPDATA%\KusPus\models on
# space-constrained machines). 75 MB+ per file — never committed.
.local-models/

# Audio capture temp files (KUSPUS_TEMP_DIR target on space-constrained machines).
.local-temp/

# Private / internal docs — local-only, never tracked. README + LICENSE +
# docs/BUILD.md, docs/INSTALL.md, docs/ARCHITECTURE.md are the public surface
# (whitelisted below). Everything else under docs/ stays local.
CLAUDE.md
docs/*
!docs/BUILD.md
!docs/INSTALL.md
!docs/ARCHITECTURE.md

# Stray icon file from a one-off design iteration (kept locally only).
icons/icon 2.svg
